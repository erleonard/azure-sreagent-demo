        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(rate(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[5m]) > 0) OR vector(0)",
          "legendFormat": "High Restart Rate Pods",
          "refId": "E"
        }
      ],
      "title": "Failure Summary",
      "type": "stat"
